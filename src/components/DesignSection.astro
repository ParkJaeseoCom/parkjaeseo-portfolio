<section id="design" style="scroll-margin-top:56px; padding:48px clamp(24px,6vw,96px) 104px; max-width:1392px; margin:0 auto; width:100%;">

  <div data-sticky-header="1" style="position:sticky; top:50px; z-index:20; background:#F7F6F2; padding:30px 0 20px; border-bottom:1px solid transparent;">
